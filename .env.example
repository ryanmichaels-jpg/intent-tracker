# Copy to .env and fill in. .env is gitignored — NEVER commit real values.

# --- Sheets append (ingest/upload_to_sheet.py) ---
# Spreadsheet ID of the canonical (work-owned) Comp_Intel_Ready sheet.
# Find it in the URL: https://docs.google.com/spreadsheets/d/<THIS_ID>/edit
COMP_INTEL_SHEET_ID=
# Tab to append to (the live sheet's source-of-truth tab).
COMP_INTEL_MASTER_TAB=Master
# Path to the service-account JSON key (kept OUTSIDE git; e.g. ~/.config/comp-intel/sa.json).
GOOGLE_SERVICE_ACCOUNT_FILE=

# --- Scrape (Apify harvestapi actors — scripts/scrape.py) ---
# Apify token: https://console.apify.com/account/integrations
# Used for BOTH scrape actors AND the profile-scraper enrichment (Current Company) —
# no separate enrichment key needed. Toggle enrichment via engagement.enrich_current_company.
APIFY_API_TOKEN=

# Anthropic key — used only to summarize Post Topic for posts the keyword-theme map misses
# (cheap Haiku call, cached per post). Without it, unmatched topics fall back to a short snippet.
ANTHROPIC_API_KEY=

# Where the scrape writes normalize-ready raw CSVs. Point this at the LOCAL path of the
# local-account Drive-for-Desktop 'comp-intel-raw' folder so files sync to Drive, e.g.:
#   ~/Library/CloudStorage/GoogleDrive-<your-account>/My Drive/comp-intel-raw
# Defaults to ./data/raw if unset (local-only, no Drive sync).
COMP_INTEL_RAW_DIR=
